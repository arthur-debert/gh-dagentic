#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")" && pwd)"

# --- Formatting ---

bold() { printf '\033[1m%s\033[0m' "$*"; }
dim() { printf '\033[2m%s\033[0m' "$*"; }

# --- Label definitions: name|color|description ---

LABELS=(
    "status: needs-plan|c5def5|Triggers the planning agent"
    "status: plan-ready|0e8a16|Plan posted, awaiting human review"
    "status: plan-approved|5319e7|Plan approved, triggers implementation"
    "pr: review-pending|fbca04|Draft PR opened, triggers side agent review"
    "pr: review-addressed|0e8a16|Review comments addressed"
    "type: feature|a2eeef|Feature request"
    "type: bug|d73a4a|Bug report"
    "type: epic|f9d0c4|Multi-PR epic"
)

# --- Helpers ---

ensure_git_repo() {
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "Error: not inside a git repository." >&2
        exit 1
    fi
    cd "$(git rev-parse --show-toplevel)"
}

ensure_github_remote() {
    local remote_url
    remote_url="$(git remote get-url origin 2>/dev/null || true)"
    if [ -z "$remote_url" ]; then
        echo "Error: no 'origin' remote found." >&2
        exit 1
    fi
    if [[ "$remote_url" != *github.com* ]]; then
        echo "Error: origin remote does not point to GitHub." >&2
        echo "  Found: $remote_url" >&2
        exit 1
    fi
}

CALLER_CHANGED=0
ISSUE_CHANGED=0

copy_files() {
    local src_dir="$1"
    local dest_dir="$2"
    local counter_var="$3"
    local changed=0

    mkdir -p "$dest_dir"
    for f in "$src_dir"/*.yml; do
        [ -f "$f" ] || continue
        local name
        name="$(basename "$f")"
        if [ -f "$dest_dir/$name" ] && diff -q "$f" "$dest_dir/$name" >/dev/null 2>&1; then
            echo "  $(dim "Unchanged $dest_dir/$name")"
        else
            local verb="Created"
            [ -f "$dest_dir/$name" ] && verb="Updated"
            cp "$f" "$dest_dir/$name"
            echo "  $verb $dest_dir/$name"
            changed=$((changed + 1))
        fi
    done

    eval "$counter_var=$changed"
}

create_labels() {
    for entry in "${LABELS[@]}"; do
        IFS='|' read -r name color description <<< "$entry"
        if gh label create "$name" --color "$color" --description "$description" --force >/dev/null 2>&1; then
            echo "  $name"
        else
            echo "  Warning: could not create label '$name'" >&2
        fi
    done
}

check_secret() {
    if ! gh secret list >/dev/null 2>&1; then
        echo "  Could not check secrets (you may not have admin access)."
        echo "  Ensure ANTHROPIC_API_KEY is set as a repository secret."
        return
    fi
    if gh secret list 2>/dev/null | grep -q "ANTHROPIC_API_KEY"; then
        echo "  ANTHROPIC_API_KEY is configured."
    else
        echo "  ANTHROPIC_API_KEY is not set. Set it with:"
        echo ""
        echo "    gh secret set ANTHROPIC_API_KEY"
        echo ""
        echo "  You'll be prompted to paste your key."
        echo "  Get one at https://console.anthropic.com/settings/keys"
    fi
}

# --- Commands ---

cmd_init() {
    echo "$(bold "Initializing Dagentic...")"
    echo ""

    ensure_git_repo
    ensure_github_remote

    echo "Installing workflow files..."
    copy_files "$SCRIPT_DIR/caller-templates" ".github/workflows" CALLER_CHANGED

    echo ""
    echo "Installing issue templates..."
    copy_files "$SCRIPT_DIR/issue-templates" ".github/ISSUE_TEMPLATE" ISSUE_CHANGED

    echo ""
    echo "Creating labels..."
    create_labels

    echo ""
    echo "Checking secrets..."
    check_secret

    echo ""
    if [ -f "CLAUDE.md" ]; then
        echo "CLAUDE.md found. The agents will use it for project-specific instructions."
    else
        echo "No CLAUDE.md found. Consider creating one with your project conventions"
        echo "(branching, testing, code style). The agents read it before every task."
    fi

    echo ""
    echo "$(bold "Done.") Create an issue using one of the templates to start the pipeline."
}

cmd_update() {
    echo "$(bold "Updating Dagentic files...")"
    echo ""

    ensure_git_repo
    ensure_github_remote

    echo "Updating workflow files..."
    copy_files "$SCRIPT_DIR/caller-templates" ".github/workflows" CALLER_CHANGED

    echo ""
    echo "Updating issue templates..."
    copy_files "$SCRIPT_DIR/issue-templates" ".github/ISSUE_TEMPLATE" ISSUE_CHANGED

    echo ""
    echo "Syncing labels..."
    create_labels

    echo ""
    local total=$((CALLER_CHANGED + ISSUE_CHANGED))
    if [ "$total" -eq 0 ]; then
        echo "Everything is up to date."
    else
        echo "$total file(s) updated. Review and commit the changes."
    fi
}

cmd_status() {
    ensure_git_repo
    ensure_github_remote

    echo "$(bold "Dagentic Pipeline Status")"
    echo ""

    echo "$(bold "Issues awaiting planning") (status: needs-plan):"
    gh issue list --label "status: needs-plan" --limit 20 2>/dev/null || echo "  (none)"
    echo ""

    echo "$(bold "Plans ready for review") (status: plan-ready):"
    gh issue list --label "status: plan-ready" --limit 20 2>/dev/null || echo "  (none)"
    echo ""

    echo "$(bold "Approved for implementation") (status: plan-approved):"
    gh issue list --label "status: plan-approved" --limit 20 2>/dev/null || echo "  (none)"
    echo ""

    echo "$(bold "PRs awaiting review") (pr: review-pending):"
    gh pr list --label "pr: review-pending" --limit 20 2>/dev/null || echo "  (none)"
    echo ""

    echo "$(bold "PRs with review addressed") (pr: review-addressed):"
    gh pr list --label "pr: review-addressed" --limit 20 2>/dev/null || echo "  (none)"
}

cmd_help() {
    cat <<HELP
$(bold "gh dagentic") — agentic development workflow orchestration

$(bold "Usage:")
  gh dagentic <command>

$(bold "Commands:")
  init      Set up Dagentic in the current repository
  update    Re-sync workflow files, issue templates, and labels
  status    Show the current state of the pipeline
  version   Show version
  help      Show this help

$(bold "Examples:")
  gh dagentic init      # First-time setup
  gh dagentic update    # After upgrading the extension
  gh dagentic status    # See what's in the pipeline
HELP
}

cmd_version() {
    echo "gh-dagentic $VERSION"
}

# --- Main ---

main() {
    local cmd="${1:-help}"
    case "$cmd" in
        init)                   cmd_init ;;
        update)                 cmd_update ;;
        status)                 cmd_status ;;
        help|--help|-h)         cmd_help ;;
        version|--version|-v)   cmd_version ;;
        *)
            echo "Unknown command: $cmd" >&2
            echo "" >&2
            cmd_help >&2
            exit 1
            ;;
    esac
}

main "$@"
